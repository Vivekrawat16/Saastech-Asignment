        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductDimension"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
    <request-map uri="deletePimProductDimension">
        <security https="true" auth="true"/>
        <event type="service" invoke="deletePimProductDimension"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>

    <!-- PimProductAssoc CRUD -->
    <request-map uri="createPimProductAssoc">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductAssoc"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
