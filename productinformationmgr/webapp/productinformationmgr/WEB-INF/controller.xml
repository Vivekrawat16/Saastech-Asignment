<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf" xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">
    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>

    <description>Productinformationmgr Component Site Configuration File</description>

    <!-- Request Mappings -->
    <request-map uri="main"><security https="true" auth="true"/><response name="success" type="view" value="main"/></request-map>
    <request-map uri="FindPimProduct"><security https="true" auth="true"/><response name="success" type="view" value="FindPimProduct"/></request-map>
    <request-map uri="PimProductDetail"><security https="true" auth="true"/><response name="success" type="view" value="PimProductDetail"/></request-map>

    <!-- PimProduct CRUD -->
    <request-map uri="createPimProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProduct"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="main"/>
    </request-map>
    <request-map uri="updatePimProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="updatePimProduct"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
    <request-map uri="deletePimProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="deletePimProduct"/>
        <response name="success" type="request-redirect" value="main"/>
        <response name="error" type="view" value="main"/>
    </request-map>

    <!-- PimProductContent CRUD -->
    <request-map uri="createPimProductContent">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductContent"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
    <request-map uri="deletePimProductContent">
        <security https="true" auth="true"/>
        <event type="service" invoke="deletePimProductContent"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>

    <!-- PimProductPrice CRUD -->
    <request-map uri="createPimProductPrice">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductPrice"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
    <request-map uri="deletePimProductPrice">
        <security https="true" auth="true"/>
        <event type="service" invoke="deletePimProductPrice"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>

    <!-- PimProductDimension CRUD -->
