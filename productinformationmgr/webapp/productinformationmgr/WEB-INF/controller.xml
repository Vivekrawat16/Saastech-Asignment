        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>

    <!-- PimProductCategoryMember CRUD -->
    <request-map uri="createPimProductCategoryMember">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductCategoryMember"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
    <request-map uri="deletePimProductCategoryMember">
        <security https="true" auth="true"/>
        <event type="service" invoke="deletePimProductCategoryMember"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>

    <!-- PimProductFeatureAppl CRUD -->
    <request-map uri="createPimProductFeatureAppl">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductFeatureAppl"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>
    <request-map uri="deletePimProductFeatureAppl">
        <security https="true" auth="true"/>
        <event type="service" invoke="deletePimProductFeatureAppl"/>
        <response name="success" type="request-redirect" value="PimProductDetail">
            <redirect-parameter name="productId"/>
        </response>
        <response name="error" type="view" value="PimProductDetail"/>
    </request-map>

    <!-- PimProductCategory CRUD -->
    <request-map uri="createPimProductCategory">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductCategory"/>
        <response name="success" type="request-redirect" value="FindPimProduct"/>
        <response name="error" type="view" value="FindPimProduct"/>
    </request-map>

    <!-- PimProductFeature CRUD -->
    <request-map uri="createPimProductFeature">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPimProductFeature"/>
        <response name="success" type="request-redirect" value="FindPimProduct"/>
        <response name="error" type="view" value="FindPimProduct"/>
    </request-map>

    <!-- View Mappings -->
    <view-map name="main" type="screen" page="component://productinformationmgr/widget/ProductinformationmgrScreens.xml#main"/>
    <view-map name="FindPimProduct" type="screen" page="component://productinformationmgr/widget/ProductinformationmgrScreens.xml#FindPimProduct"/>
    <view-map name="PimProductDetail" type="screen" page="component://productinformationmgr/widget/ProductinformationmgrScreens.xml#PimProductDetail"/>
</site-conf>