<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">
    <!-- ========================================================= -->
    <!-- ======================== Defaults ======================= -->
    <!-- ========================================================= -->
    <title>Entity of Ordermgmtsystem Component</title>
    <description>Entities for Order Management System</description>
    <copyright></copyright>
    <version></version>

    <!-- 1. OmsOrderHeader -->
    <entity entity-name="OmsOrderHeader" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Header">
        <field name="orderId" type="id"/>
        <field name="orderTypeId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="orderDate" type="date-time"/>
        <prim-key field="orderId"/>
    </entity>

    <!-- 2. OmsOrderPart -->
    <entity entity-name="OmsOrderPart" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Part">
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="customerPartyId" type="id"/>
        <field name="vendorPartyId" type="id"/>
        <field name="postalContactMechId" type="id"/>
        <field name="telecomContactMechId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="partTotal" type="currency-amount"/>
        <prim-key field="orderId"/>
        <prim-key field="orderPartSeqId"/>
        <relation type="one" fk-name="OMS_OPART_HDR" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
    </entity>

    <!-- 3. OmsOrderItem -->
    <entity entity-name="OmsOrderItem" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Item">
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="productId" type="id"/>
        <field name="quantity" type="fixed-point"/>
        <field name="unitPrice" type="currency-amount"/>
        <field name="parentOrderItemSeqId" type="id"/>
        <prim-key field="orderId"/>
        <prim-key field="orderPartSeqId"/>
        <prim-key field="orderItemSeqId"/>
        <relation type="one" fk-name="OMS_OITEM_PART" rel-entity-name="OmsOrderPart">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
        </relation>
        <relation type="one" fk-name="OMS_OITEM_PARENT" rel-entity-name="OmsOrderItem" title="Parent">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
            <key-map field-name="parentOrderItemSeqId" rel-field-name="orderItemSeqId"/>
        </relation>
    </entity>

    <!-- 4. OmsOrderContactMech -->
    <entity entity-name="OmsOrderContactMech" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Contact Mech">
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="contactMechPurposeTypeId" type="id"/>
        <field name="contactMechId" type="id"/>
        <prim-key field="orderId"/>
        <prim-key field="orderPartSeqId"/>
        <prim-key field="contactMechPurposeTypeId"/>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="OMS_OCM_PART" rel-entity-name="OmsOrderPart">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
        </relation>
    </entity>

    <!-- 5. OmsOrderStatus -->
    <entity entity-name="OmsOrderStatus" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Status">
        <field name="orderStatusId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="statusDatetime" type="date-time"/>
        <prim-key field="orderStatusId"/>
        <relation type="one" fk-name="OMS_OSTAT_HDR" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
        <relation type="one" fk-name="OMS_OSTAT_PART" rel-entity-name="OmsOrderPart" title="Part">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
        </relation>
    </entity>

    <!-- 6. OmsOrderAdjustment -->
    <entity entity-name="OmsOrderAdjustment" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Adjustment">
        <field name="orderAdjustmentId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="orderAdjustmentTypeId" type="id"/>
        <field name="amount" type="currency-amount"/>
        <field name="description" type="description"/>
        <prim-key field="orderAdjustmentId"/>
        <relation type="one" fk-name="OMS_OADJ_PART" rel-entity-name="OmsOrderPart">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
        </relation>
    </entity>

    <!-- 7. OmsOrderPayment -->
    <entity entity-name="OmsOrderPayment" package-name="org.apache.ofbiz.ordermgmtsystem" title="OMS Order Payment">
        <field name="orderPaymentId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="paymentMethodTypeId" type="id"/>
        <field name="amount" type="currency-amount"/>
        <field name="statusId" type="id"/>
        <prim-key field="orderPaymentId"/>
        <relation type="one" fk-name="OMS_OPAY_PART" rel-entity-name="OmsOrderPart">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
        </relation>
    </entity>

</entitymodel>