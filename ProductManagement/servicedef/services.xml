<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>ProductManagement Services</description>
    <vendor></vendor>
    <version>1.0</version>

    <!-- findProduct Service -->
    <service name="findProduct" engine="groovy" location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="findProduct" auth="true">
        <attribute name="productId" type="String" mode="IN" optional="true"/>
        <attribute name="productName" type="String" mode="IN" optional="true"/>
        <attribute name="minPrice" type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="maxPrice" type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="productCategoryId" type="String" mode="IN" optional="true"/>
        <attribute name="productFeatureId" type="String" mode="IN" optional="true"/>
        <attribute name="productList" type="List" mode="OUT" optional="true"/>
    </service>

    <!-- createProduct Service -->
    <service name="createProduct" engine="groovy" location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="createProduct" auth="true">
        <attribute name="productId" type="String" mode="IN" optional="true"/>
        <attribute name="productName" type="String" mode="IN" optional="false"/>
        <attribute name="productCategoryId" type="String" mode="IN" optional="false"/>
        <attribute name="price" type="BigDecimal" mode="IN" optional="false"/>
        <attribute name="isVirtual" type="String" mode="IN" optional="true"/>
        <attribute name="isVariant" type="String" mode="IN" optional="true"/>
        <attribute name="productIdResult" type="String" mode="OUT" optional="true"/>
    </service>

    <!-- updateProduct Service -->
    <service name="updateProduct" engine="groovy" location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="updateProduct" auth="true">
        <attribute name="productId" type="String" mode="IN" optional="false"/>
        <attribute name="price" type="BigDecimal" mode="IN" optional="true"/>
        <attribute name="productFeatureId" type="String" mode="IN" optional="true"/>
    </service>

    <!-- assocProductToVirtual Service -->
    <service name="assocProductToVirtual" engine="groovy" location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="assocProductToVirtual" auth="true">
        <attribute name="productId" type="String" mode="IN" optional="false"/>
        <attribute name="virtualProductId" type="String" mode="IN" optional="false"/>
    </service>

    <!-- updateProductVariant Service -->
    <service name="updateProductVariant" engine="groovy" location="component://ProductManagement/groovyScripts/ProductServices.groovy" invoke="updateProductVariant" auth="true">
        <attribute name="productId" type="String" mode="IN" optional="false"/>
        <attribute name="virtualProductId" type="String" mode="IN" optional="false"/>
        <attribute name="thruDate" type="Timestamp" mode="IN" optional="true"/>
    </service>

</services>