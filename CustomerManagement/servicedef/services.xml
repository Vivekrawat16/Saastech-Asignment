<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/services.xsd">
    <description>CustomerManagement Services</description>
    <vendor></vendor>
    <version>1.0</version>

    <!-- Find Customer Service -->
    <service name="findCustomer" engine="groovy" location="component://CustomerManagement/groovyScripts/CustomerServices.groovy" invoke="findCustomer">
        <description>Finds customers based on various search criteria with case-insensitive and partial matching</description>
        <attribute name="partyId" type="String" mode="IN" optional="true"/>
        <attribute name="emailAddress" type="String" mode="IN" optional="true"/>
        <attribute name="firstName" type="String" mode="IN" optional="true"/>
        <attribute name="lastName" type="String" mode="IN" optional="true"/>
        <attribute name="contactNumber" type="String" mode="IN" optional="true"/>
        <attribute name="address1" type="String" mode="IN" optional="true"/>
        <attribute name="city" type="String" mode="IN" optional="true"/>
        <attribute name="stateProvinceGeoId" type="String" mode="IN" optional="true"/>
        <attribute name="postalCode" type="String" mode="IN" optional="true"/>
        <attribute name="countryGeoId" type="String" mode="IN" optional="true"/>
        <attribute name="customerList" type="java.util.List" mode="OUT" optional="true"/>
    </service>

    <!-- Create Customer Service -->
    <service name="createCustomer" engine="groovy" location="component://CustomerManagement/groovyScripts/CustomerServices.groovy" invoke="createCustomer">
        <description>Creates a customer if they do not already exist, and assigns their email, phone, and address</description>
        <attribute name="emailAddress" type="String" mode="IN" optional="false"/>
        <attribute name="firstName" type="String" mode="IN" optional="false"/>
        <attribute name="lastName" type="String" mode="IN" optional="false"/>
        <attribute name="contactNumber" type="String" mode="IN" optional="true"/>
        <attribute name="address1" type="String" mode="IN" optional="true"/>
        <attribute name="address2" type="String" mode="IN" optional="true"/>
        <attribute name="city" type="String" mode="IN" optional="true"/>
        <attribute name="stateProvinceGeoId" type="String" mode="IN" optional="true"/>
        <attribute name="postalCode" type="String" mode="IN" optional="true"/>
        <attribute name="countryGeoId" type="String" mode="IN" optional="true"/>
        <attribute name="partyIdResult" type="String" mode="OUT" optional="true"/>
    </service>

    <!-- Update Customer Service -->
    <service name="updateCustomer" engine="groovy" location="component://CustomerManagement/groovyScripts/CustomerServices.groovy" invoke="updateCustomer">
        <description>Updates an existing customer's contact number and/or postal address details</description>
        <attribute name="emailAddress" type="String" mode="IN" optional="false"/>
        <attribute name="contactNumber" type="String" mode="IN" optional="true"/>
        <attribute name="address1" type="String" mode="IN" optional="true"/>
        <attribute name="address2" type="String" mode="IN" optional="true"/>
        <attribute name="city" type="String" mode="IN" optional="true"/>
        <attribute name="stateProvinceGeoId" type="String" mode="IN" optional="true"/>
        <attribute name="postalCode" type="String" mode="IN" optional="true"/>
        <attribute name="countryGeoId" type="String" mode="IN" optional="true"/>
    </service>

    <!-- Create Customer Relationship Service -->
    <service name="createCustomerRelationship" engine="groovy" location="component://CustomerManagement/groovyScripts/CustomerServices.groovy" invoke="createCustomerRelationship">
        <description>Creates a relationship between two parties</description>
        <attribute name="partyIdFrom" type="String" mode="IN" optional="false"/>
        <attribute name="partyIdTo" type="String" mode="IN" optional="false"/>
        <attribute name="roleTypeIdFrom" type="String" mode="IN" optional="true" default-value="_NA_"/>
        <attribute name="roleTypeIdTo" type="String" mode="IN" optional="true" default-value="_NA_"/>
        <attribute name="partyRelationshipTypeId" type="String" mode="IN" optional="false"/>
        <attribute name="statusId" type="String" mode="IN" optional="true"/>
    </service>

    <!-- Update Customer Relationship Service -->
    <service name="updateCustomerRelationship" engine="groovy" location="component://CustomerManagement/groovyScripts/CustomerServices.groovy" invoke="updateCustomerRelationship">
        <description>Updates an existing relationship status or thruDate between two parties</description>
        <attribute name="partyIdFrom" type="String" mode="IN" optional="false"/>
        <attribute name="partyIdTo" type="String" mode="IN" optional="false"/>
        <attribute name="roleTypeIdFrom" type="String" mode="IN" optional="true" default-value="_NA_"/>
        <attribute name="roleTypeIdTo" type="String" mode="IN" optional="true" default-value="_NA_"/>
        <attribute name="partyRelationshipTypeId" type="String" mode="IN" optional="false"/>
        <attribute name="fromDate" type="java.sql.Timestamp" mode="IN" optional="false"/>
        <attribute name="thruDate" type="java.sql.Timestamp" mode="IN" optional="true"/>
        <attribute name="statusId" type="String" mode="IN" optional="true"/>
    </service>
</services>